---
import "../styles/global.css";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";

const {
  title = "Derlis Gamarra | Blue Team Portfolio",
  description = "Portafolio profesional de Derlis Gamarra, SOC Analyst L1 enfocado en Blue Team, monitoreo, análisis de alertas, laboratorios defensivos y crecimiento hacia roles más avanzados en ciberseguridad."
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_PY" />

    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
  </body>
</html>