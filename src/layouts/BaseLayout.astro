---
import "../styles/global.css";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";

const {
  title = "Derlis Gamarra | Blue Team Portfolio",
  description = "Portafolio profesional de Derlis Gamarra, SOC Analyst L1 enfocado en Blue Team, monitoreo, análisis de alertas, laboratorios defensivos y crecimiento hacia roles más avanzados en ciberseguridad."
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta property="og:title" content="Derlis Gamarra — SOC Analyst L1 | Cybersecurity Portfolio" />
    <meta property="og:description" content="SOC Analyst L1 focused on Blue Team operations, SIEM monitoring, incident triage and defensive cybersecurity engineering." />
    <meta property="og:image" content="https://dgamarra.netlify.app/og-image.png" />
    <meta property="og:url" content="https://dgamarra.netlify.app" />
    <meta property="og:type" content="website" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Derlis Gamarra — SOC Analyst L1 | Cybersecurity Portfolio" />
    <meta name="twitter:description" content="Blue Team cybersecurity portfolio focused on incident response, SIEM monitoring and threat detection." />
    <meta name="twitter:image" content="https://dgamarra.netlify.app/og-image.png" />
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
  </body>
</html>