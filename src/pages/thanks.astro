---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Gracias | Derlis Gamarra">
  <main class="section">
    <div class="container">
      <div class="card" style="max-width: 720px; margin: 0 auto; text-align: center;">
        <div class="badge">Mensaje enviado</div>
        <h1 class="section-title">Gracias por contactarme</h1>
        <p class="section-subtitle" style="margin: 0 auto;">
          Recibí tu mensaje correctamente. En cuanto me sea posible, te responderé.
        </p>

        <div class="hero-actions" style="justify-content: center; margin-top: 2rem;">
          <a href="/" class="btn btn-primary">Volver al inicio</a>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>